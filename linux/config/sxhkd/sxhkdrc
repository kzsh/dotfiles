alt + shift + 4
	/usr/local/bin/screencap

ctrl + alt + shift + 4
	/usr/bin/flameshot gui

ctrl + alt + Escape
	/usr/local/bin/hibernate

ctrl + shift + alt + k
	/usr/local/bin/setup -k && /usr/bin/notify-send "Keyboard remapped"

ctrl + alt + shift + q
	/usr/local/bin/lock


#  ctrl + alt + shift + j
mod3 + shift
	i3-msg mode "resize"

#  ctrl + alt + shift + j
mod3 + k;
	i3-msg mode "switch_space_set"

ctrl + shift + h
	~/bin/key-handler "$(~/bin/get-window-class)" "ctrl + shift + h"

ctrl + shift + l
	~/bin/key-handler "$(~/bin/get-window-class)" "ctrl + shift + l"

ctrl + shift + r
	~/bin/key-handler "$(~/bin/get-window-class)" "ctrl + shift + r"

#
# wm independent hotkeys
#

# terminal emulator
super + Return
	~/bin/i3-shell

ctrl + shift + alt + r
	systemctl --user reload sxhkd &&  notify-send 'sxhkd restarted'

mod1 + @space
	rofi -sorting-method fzf -modi drun\,run -show run
